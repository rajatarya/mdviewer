{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Markdown Viewer",
  "version": "1.2.0",
  "identifier": "app.mdviewer",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Markdown Viewer",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "txt"],
        "name": "Markdown",
        "role": "Viewer",
        "contentTypes": ["public.plain-text", "public.text"]
      }
    ]
  },
  "plugins": {
    "cli": {
      "description": "A lightweight Markdown viewer",
      "args": [
        {
          "name": "help",
          "short": "h",
          "long": "help",
          "takes_value": false,
          "help": "Print this help message and exit"
        },
        {
          "name": "files",
          "index": 1,
          "takes_value": true,
          "multiple": true,
          "required": false,
          "description": "Markdown files to open"
        }
      ]
    }
  }
}
